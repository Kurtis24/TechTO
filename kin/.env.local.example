# Copy to .env.local and fill in.
# Convex values are generated by `npx convex dev` on first run.

NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# These two also need to be set in the Convex dashboard
# (Settings → Environment Variables) so server-side actions can read them.
BACKBOARD_API_KEY=
ELEVENLABS_API_KEY=
